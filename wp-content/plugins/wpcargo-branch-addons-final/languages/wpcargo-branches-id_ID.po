#: admin/templates/transfer.tpl.php:19
msgid ""
"Scan your shipment barcode to update or enter the tracking number and press "
"ENTER"
msgstr ""
"Pindai kode batang pengiriman Anda untuk memperbarui atau memasukkan nomor "
"pelacakan dan tekan ENTER"

#: admin/templates/transfer.tpl.php:22
msgid "Notes"
